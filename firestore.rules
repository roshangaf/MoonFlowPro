
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return isSignedIn() && request.auth.token.email == 'roshanismean@gmail.com';
    }

    // A user is "Staff" if they are signed in AND have been approved by an admin
    function isApprovedStaff() {
      return isSignedIn() && (
        isSuperAdmin() ||
        (exists(/databases/$(database)/documents/businessUsers/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/businessUsers/$(request.auth.uid)).data.approved == true)
      );
    }

    function getUserData() {
      return get(/databases/$(database)/documents/businessUsers/$(request.auth.uid)).data;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Checks if the document belongs to the user's company or if the user is a super admin
    function belongsToCompany(resourceData) {
      return isSuperAdmin() || (isApprovedStaff() && resourceData.companyId == getUserData().companyId);
    }

    // --- COLLECTION RULES ---

    match /businessUsers/{userId} {
      allow get: if isOwner(userId) || isSuperAdmin() || (isApprovedStaff() && getUserData().companyId == resource.data.companyId);
      allow list: if isSuperAdmin() || (isApprovedStaff() && (query.limit <= 100));
      
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isSuperAdmin() || (isApprovedStaff() && getUserData().companyId == resource.data.companyId && getUserData().role == 'admin');
      allow delete: if isSuperAdmin();
    }

    match /admins/{userId} {
      allow get: if isSignedIn();
      allow list: if isSuperAdmin();
      allow create, update, delete: if isSuperAdmin();
    }

    match /customers/{customerId} {
      allow create: if isApprovedStaff();
      allow get, list, update, delete: if belongsToCompany(resource.data);
    }

    match /products/{productId} {
      allow create: if isApprovedStaff();
      allow get, list, update, delete: if belongsToCompany(resource.data);
      
      match /repairLogs/{repairLogId} {
        allow get, list, create, update, delete: if isApprovedStaff();
      }
    }

    match /sales/{saleId} {
      allow create: if isApprovedStaff();
      allow get, list, update, delete: if belongsToCompany(resource.data);
    }

    match /reminders/{reminderId} {
      allow get, list, create, update, delete: if belongsToCompany(resource.data);
    }
  }
}
